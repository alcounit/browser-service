{
  "metadata": {
    "name": "test-config"
  },
  "spec": {
    "template": {
      "labels": {
        "app": "browser"
      },
      "env": [
        { "name": "SCREEN_RESOLUTION", "value": "1920x1080" },
        { "name": "DISPLAY",           "value": "127.0.0.1:0" }
      ],
      "workingDir": "/home/user",
      "securityContext": {
        "runAsGroup": 4096,
        "runAsUser":  4096
      },
      "resources": {
        "requests": { "cpu": "250m",  "memory": "512Mi" },
        "limits":   { "cpu": "500m",  "memory": "1Gi"   }
      },
      "sidecars": [
        {
          "name":            "seleniferous",
          "image":           "192.168.1.101:30000/seleniferous:develop",
          "imagePullPolicy": "Always",
          "env": [
            { "name": "SESSION_CREATE_TIMEOUT", "value": "10m" },
            { "name": "SESSION_IDLE_TIMEOUT",   "value": "10m" },
            { "name": "BROWSER_PATH",           "value": "/" },
            { "name": "BROWSER_PORT",           "value": "4444" },
            { "name": "DISPLAY",                "value": "127.0.0.1:0" },
            {
              "name": "POD_IP",
              "valueFrom": { "fieldRef": { "fieldPath": "status.podIP" } }
            }
          ],
          "resources": {
            "requests": { "cpu": "100m", "memory": "64Mi"  },
            "limits":   { "cpu": "200m", "memory": "128Mi" }
          },
          "volumeMounts": [
            { "mountPath": "/dev/shm",       "name": "dshm"      },
            { "mountPath": "/tmp",            "name": "tmp"       },
            { "mountPath": "/etc/passwd",     "name": "usergroup", "subPath": "passwd" },
            { "mountPath": "/etc/group",      "name": "usergroup", "subPath": "group"  },
            { "mountPath": "/home/user",      "name": "home"      },
            { "mountPath": "/home/user/Downloads", "name": "downloads" }
          ]
        },
        {
          "name":  "x-server",
          "image": "quay.io/aerokube/xvfb:21.1-1",
          "env": [
            { "name": "SCREEN_RESOLUTION", "value": "1920x1080" },
            { "name": "DISPLAY",           "value": "127.0.0.1:0" }
          ],
          "ports": [{ "containerPort": 6000 }],
          "resources": {
            "requests": { "cpu": "100m", "memory": "128Mi" },
            "limits":   { "cpu": "200m", "memory": "128Mi" }
          },
          "volumeMounts": [
            { "mountPath": "/dev/shm",       "name": "dshm"      },
            { "mountPath": "/tmp",            "name": "tmp"       },
            { "mountPath": "/etc/group",      "name": "usergroup", "subPath": "group"  },
            { "mountPath": "/etc/passwd",     "name": "usergroup", "subPath": "passwd" },
            { "mountPath": "/home/user",      "name": "home"      },
            { "mountPath": "/home/user/Downloads", "name": "downloads" }
          ],
          "workingDir": "/home/user"
        },
        {
          "name":  "window-manager",
          "image": "quay.io/aerokube/openbox:3.6.1-1",
          "env": [
            { "name": "DISPLAY", "value": "127.0.0.1:0" }
          ],
          "resources": {
            "requests": { "cpu": "100m", "memory": "128Mi" },
            "limits":   { "cpu": "200m", "memory": "128Mi" }
          },
          "volumeMounts": [
            { "mountPath": "/dev/shm",       "name": "dshm"      },
            { "mountPath": "/tmp",            "name": "tmp"       },
            { "mountPath": "/etc/group",      "name": "usergroup", "subPath": "group"  },
            { "mountPath": "/etc/passwd",     "name": "usergroup", "subPath": "passwd" },
            { "mountPath": "/home/user",      "name": "home"      },
            { "mountPath": "/home/user/Downloads", "name": "downloads" }
          ],
          "workingDir": "/home/user"
        },
        {
          "name":  "vnc-server",
          "image": "quay.io/aerokube/x11vnc:0.9.16-1",
          "env": [
            { "name": "DISPLAY", "value": "127.0.0.1:0" }
          ],
          "ports": [{ "containerPort": 5900 }],
          "resources": {
            "requests": { "cpu": "100m", "memory": "128Mi" },
            "limits":   { "cpu": "200m", "memory": "128Mi" }
          },
          "volumeMounts": [
            { "mountPath": "/dev/shm",       "name": "dshm"      },
            { "mountPath": "/tmp",            "name": "tmp"       },
            { "mountPath": "/etc/group",      "name": "usergroup", "subPath": "group"  },
            { "mountPath": "/etc/passwd",     "name": "usergroup", "subPath": "passwd" },
            { "mountPath": "/home/user",      "name": "home"      },
            { "mountPath": "/home/user/Downloads", "name": "downloads" }
          ],
          "workingDir": "/home/user"
        }
      ],
      "volumes": [
        { "name": "dshm",      "emptyDir": { "medium": "Memory" } },
        { "name": "tmp",       "emptyDir": { "medium": "Memory" } },
        { "name": "home",      "emptyDir": { "medium": "Memory" } },
        { "name": "downloads", "emptyDir": {} },
        {
          "name": "usergroup",
          "configMap": { "defaultMode": 420, "name": "usergroup" }
        }
      ],
      "volumeMounts": [
        { "mountPath": "/dev/shm",       "name": "dshm"      },
        { "mountPath": "/tmp",            "name": "tmp"       },
        { "mountPath": "/etc/group",      "name": "usergroup", "subPath": "group"  },
        { "mountPath": "/etc/passwd",     "name": "usergroup", "subPath": "passwd" },
        { "mountPath": "/home/user",      "name": "home"      },
        { "mountPath": "/home/user/Downloads", "name": "downloads" }
      ]
    },
    "browsers": {
      "chrome": {
        "131.0": { "image": "quay.io/browser/google-chrome-stable:131.0" },
        "132.0": { "image": "quay.io/browser/google-chrome-stable:132.0" },
        "133.0": { "image": "quay.io/browser/google-chrome-stable:133.0" },
        "134.0": { "image": "quay.io/browser/google-chrome-stable:134.0" },
        "135.0": { "image": "quay.io/browser/google-chrome-stable:135.0" },
        "136.0": { "image": "quay.io/browser/google-chrome-stable:136.0" },
        "137.0": { "image": "quay.io/browser/google-chrome-stable:137.0" },
        "138.0": { "image": "quay.io/browser/google-chrome-stable:138.0" },
        "139.0": { "image": "quay.io/browser/google-chrome-stable:139.0" },
        "140.0": { "image": "quay.io/browser/google-chrome-stable:140.0" },
        "141.0": { "image": "quay.io/browser/google-chrome-stable:141.0" },
        "142.0": { "image": "quay.io/browser/google-chrome-stable:142.0" },
        "143.0": { "image": "quay.io/browser/google-chrome-stable:143.0" },
        "144.0": { "image": "quay.io/browser/google-chrome-stable:144.0" },
        "145.0": { "image": "quay.io/browser/google-chrome-stable:145.0" },
        "146.0": { "image": "quay.io/browser/google-chrome-stable:146.0" }
      }
    }
  }
}
